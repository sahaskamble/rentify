15694: /**
15695:  * Package context defines the Context type, which carries deadlines,
15696:  * cancellation signals, and other request-scoped values across API boundaries
15697:  * and between processes.
15698:  * 
15699:  * Incoming requests to a server should create a [Context], and outgoing
15700:  * calls to servers should accept a Context. The chain of function
15701:  * calls between them must propagate the Context, optionally replacing
15702:  * it with a derived Context created using [WithCancel], [WithDeadline],
15703:  * [WithTimeout], or [WithValue].
15704:  * 
15705:  * A Context may be canceled to indicate that work done on its behalf should stop.
15706:  * A Context with a deadline is canceled after the deadline passes.
15707:  * When a Context is canceled, all Contexts derived from it are also canceled.
15708:  * 
15709:  * The [WithCancel], [WithDeadline], and [WithTimeout] functions take a
15710:  * Context (the parent) and return a derived Context (the child) and a
15711:  * [CancelFunc]. Calling the CancelFunc directly cancels the child and its
15712:  * children, removes the parent's reference to the child, and stops
15713:  * any associated timers. Failing to call the CancelFunc leaks the
15714:  * child and its children until the parent is canceled. The go vet tool
15715:  * checks that CancelFuncs are used on all control-flow paths.
15716:  * 
15717:  * The [WithCancelCause], [WithDeadlineCause], and [WithTimeoutCause] functions
15718:  * return a [CancelCauseFunc], which takes an error and records it as
15719:  * the cancellation cause. Calling [Cause] on the canceled context
15720:  * or any of its children retrieves the cause. If no cause is specified,
15721:  * Cause(ctx) returns the same value as ctx.Err().
15722:  * 
15723:  * Programs that use Contexts should follow these rules to keep interfaces
15724:  * consistent across packages and enable static analysis tools to check context
15725:  * propagation:
15726:  * 
15727:  * Do not store Contexts inside a struct type; instead, pass a Context
15728:  * explicitly to each function that needs it. This is discussed further in
15729:  * https://go.dev/blog/context-and-structs. The Context should be the first
15730:  * parameter, typically named ctx:
15731:  * 
15732:  * ```
15733:  * 	func DoSomething(ctx context.Context, arg Arg) error {
15734:  * 		// ... use ctx ...
15735:  * 	}
15736:  * ```
15737:  * 
15738:  * Do not pass a nil [Context], even if a function permits it. Pass [context.TODO]
15739:  * if you are unsure about which Context to use.
15740:  * 
15741:  * Use context Values only for request-scoped data that transits processes and
15742:  * APIs, not for passing optional parameters to functions.
15743:  * 
15744:  * The same Context may be passed to functions running in different goroutines;
15745:  * Contexts are safe for simultaneous use by multiple goroutines.
15746:  * 
15747:  * See https://go.dev/blog/context for example code for a server that uses
15748:  * Contexts.
15749:  */
15750: namespace context {
15751:  /**
15752:   * A Context carries a deadline, a cancellation signal, and other values across
15753:   * API boundaries.
15754:   * 
15755:   * Context's methods may be called by multiple goroutines simultaneously.
15756:   */
15757:  interface Context {
15758:   [key:string]: any;
15759:   /**
15760:    * Deadline returns the time when work done on behalf of this context
15761:    * should be canceled. Deadline returns ok==false when no deadline is
15762:    * set. Successive calls to Deadline return the same results.
15763:    */
15764:   deadline(): [time.Time, boolean]
15765:   /**
15766:    * Done returns a channel that's closed when work done on behalf of this
15767:    * context should be canceled. Done may return nil if this context can
15768:    * never be canceled. Successive calls to Done return the same value.
15769:    * The close of the Done channel may happen asynchronously,
15770:    * after the cancel function returns.
15771:    * 
15772:    * WithCancel arranges for Done to be closed when cancel is called;
15773:    * WithDeadline arranges for Done to be closed when the deadline
15774:    * expires; WithTimeout arranges for Done to be closed when the timeout
15775:    * elapses.
15776:    * 
15777:    * Done is provided for use in select statements:
15778:    * 
15779:    *  // Stream generates values with DoSomething and sends them to out
15780:    *  // until DoSomething returns an error or ctx.Done is closed.
15781:    *  func Stream(ctx context.Context, out chan<- Value) error {
15782:    *  	for {
15783:    *  		v, err := DoSomething(ctx)
15784:    *  		if err != nil {
15785:    *  			return err
15786:    *  		}
15787:    *  		select {
15788:    *  		case <-ctx.Done():
15789:    *  			return ctx.Err()
15790:    *  		case out <- v:
15791:    *  		}
15792:    *  	}
15793:    *  }
15794:    * 
15795:    * See https://blog.golang.org/pipelines for more examples of how to use
15796:    * a Done channel for cancellation.
15797:    */
15798:   done(): undefined
15799:   /**
15800:    * If Done is not yet closed, Err returns nil.
15801:    * If Done is closed, Err returns a non-nil error explaining why:
15802:    * DeadlineExceeded if the context's deadline passed,
15803:    * or Canceled if the context was canceled for some other reason.
15804:    * After Err returns a non-nil error, successive calls to Err return the same error.
15805:    */
15806:   err(): void
15807:   /**
15808:    * Value returns the value associated with this context for key, or nil
15809:    * if no value is associated with key. Successive calls to Value with
15810:    * the same key returns the same result.
15811:    * 
15812:    * Use context values only for request-scoped data that transits
15813:    * processes and API boundaries, not for passing optional parameters to
15814:    * functions.
15815:    * 
15816:    * A key identifies a specific value in a Context. Functions that wish
15817:    * to store values in Context typically allocate a key in a global
15818:    * variable then use that key as the argument to context.WithValue and
15819:    * Context.Value. A key can be any type that supports equality;
15820:    * packages should define keys as an unexported type to avoid
15821:    * collisions.
15822:    * 
15823:    * Packages that define a Context key should provide type-safe accessors
15824:    * for the values stored using that key:
15825:    * 
15826:    * ```
15827:    * 	// Package user defines a User type that's stored in Contexts.
15828:    * 	package user
15829:    * 
15830:    * 	import "context"
15831:    * 
15832:    * 	// User is the type of value stored in the Contexts.
15833:    * 	type User struct {...}
15834:    * 
15835:    * 	// key is an unexported type for keys defined in this package.
15836:    * 	// This prevents collisions with keys defined in other packages.
15837:    * 	type key int
15838:    * 
15839:    * 	// userKey is the key for user.User values in Contexts. It is
15840:    * 	// unexported; clients use user.NewContext and user.FromContext
15841:    * 	// instead of using this key directly.
15842:    * 	var userKey key
15843:    * 
15844:    * 	// NewContext returns a new Context that carries value u.
15845:    * 	func NewContext(ctx context.Context, u *User) context.Context {
15846:    * 		return context.WithValue(ctx, userKey, u)
15847:    * 	}
15848:    * 
15849:    * 	// FromContext returns the User value stored in ctx, if any.
15850:    * 	func FromContext(ctx context.Context) (*User, bool) {
15851:    * 		u, ok := ctx.Value(userKey).(*User)
15852:    * 		return u, ok
15853:    * 	}
15854:    * ```
15855:    */
15856:   value(key: any): any
15857:  }
15858: }
