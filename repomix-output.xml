21085: /**
21086:  * Package slog provides structured logging,
21087:  * in which log records include a message,
21088:  * a severity level, and various other attributes
21089:  * expressed as key-value pairs.
21090:  * 
21091:  * It defines a type, [Logger],
21092:  * which provides several methods (such as [Logger.Info] and [Logger.Error])
21093:  * for reporting events of interest.
21094:  * 
21095:  * Each Logger is associated with a [Handler].
21096:  * A Logger output method creates a [Record] from the method arguments
21097:  * and passes it to the Handler, which decides how to handle it.
21098:  * There is a default Logger accessible through top-level functions
21099:  * (such as [Info] and [Error]) that call the corresponding Logger methods.
21100:  * 
21101:  * A log record consists of a time, a level, a message, and a set of key-value
21102:  * pairs, where the keys are strings and the values may be of any type.
21103:  * As an example,
21104:  * 
21105:  * ```
21106:  * 	slog.Info("hello", "count", 3)
21107:  * ```
21108:  * 
21109:  * creates a record containing the time of the call,
21110:  * a level of Info, the message "hello", and a single
21111:  * pair with key "count" and value 3.
21112:  * 
21113:  * The [Info] top-level function calls the [Logger.Info] method on the default Logger.
21114:  * In addition to [Logger.Info], there are methods for Debug, Warn and Error levels.
21115:  * Besides these convenience methods for common levels,
21116:  * there is also a [Logger.Log] method which takes the level as an argument.
21117:  * Each of these methods has a corresponding top-level function that uses the
21118:  * default logger.
21119:  * 
21120:  * The default handler formats the log record's message, time, level, and attributes
21121:  * as a string and passes it to the [log] package.
21122:  * 
21123:  * ```
21124:  * 	2022/11/08 15:28:26 INFO hello count=3
21125:  * ```
21126:  * 
21127:  * For more control over the output format, create a logger with a different handler.
21128:  * This statement uses [New] to create a new logger with a [TextHandler]
21129:  * that writes structured records in text form to standard error:
21130:  * 
21131:  * ```
21132:  * 	logger := slog.New(slog.NewTextHandler(os.Stderr, nil))
21133:  * ```
21134:  * 
21135:  * [TextHandler] output is a sequence of key=value pairs, easily and unambiguously
21136:  * parsed by machine. This statement:
21137:  * 
21138:  * ```
21139:  * 	logger.Info("hello", "count", 3)
21140:  * ```
21141:  * 
21142:  * produces this output:
21143:  * 
21144:  * ```
21145:  * 	time=2022-11-08T15:28:26.000-05:00 level=INFO msg=hello count=3
21146:  * ```
21147:  * 
21148:  * The package also provides [JSONHandler], whose output is line-delimited JSON:
21149:  * 
21150:  * ```
21151:  * 	logger := slog.New(slog.NewJSONHandler(os.Stdout, nil))
21152:  * 	logger.Info("hello", "count", 3)
21153:  * ```
21154:  * 
21155:  * produces this output:
21156:  * 
21157:  * ```
21158:  * 	{"time":"2022-11-08T15:28:26.000000000-05:00","level":"INFO","msg":"hello","count":3}
21159:  * ```
21160:  * 
21161:  * Both [TextHandler] and [JSONHandler] can be configured with [HandlerOptions].
21162:  * There are options for setting the minimum level (see Levels, below),
21163:  * displaying the source file and line of the log call, and
21164:  * modifying attributes before they are logged.
21165:  * 
21166:  * Setting a logger as the default with
21167:  * 
21168:  * ```
21169:  * 	slog.SetDefault(logger)
21170:  * ```
21171:  * 
21172:  * will cause the top-level functions like [Info] to use it.
21173:  * [SetDefault] also updates the default logger used by the [log] package,
21174:  * so that existing applications that use [log.Printf] and related functions
21175:  * will send log records to the logger's handler without needing to be rewritten.
21176:  * 
21177:  * Some attributes are common to many log calls.
21178:  * For example, you may wish to include the URL or trace identifier of a server request
21179:  * with all log events arising from the request.
21180:  * Rather than repeat the attribute with every log call, you can use [Logger.With]
21181:  * to construct a new Logger containing the attributes:
21182:  * 
21183:  * ```
21184:  * 	logger2 := logger.With("url", r.URL)
21185:  * ```
21186:  * 
21187:  * The arguments to With are the same key-value pairs used in [Logger.Info].
21188:  * The result is a new Logger with the same handler as the original, but additional
21189:  * attributes that will appear in the output of every call.
21190:  * 
21191:  * # Levels
21192:  * 
21193:  * A [Level] is an integer representing the importance or severity of a log event.
21194:  * The higher the level, the more severe the event.
21195:  * This package defines constants for the most common levels,
21196:  * but any int can be used as a level.
21197:  * 
21198:  * In an application, you may wish to log messages only at a certain level or greater.
21199:  * One common configuration is to log messages at Info or higher levels,
21200:  * suppressing debug logging until it is needed.
21201:  * The built-in handlers can be configured with the minimum level to output by
21202:  * setting [HandlerOptions.Level].
21203:  * The program's `main` function typically does this.
21204:  * The default value is LevelInfo.
21205:  * 
21206:  * Setting the [HandlerOptions.Level] field to a [Level] value
21207:  * fixes the handler's minimum level throughout its lifetime.
21208:  * Setting it to a [LevelVar] allows the level to be varied dynamically.
21209:  * A LevelVar holds a Level and is safe to read or write from multiple
21210:  * goroutines.
21211:  * To vary the level dynamically for an entire program, first initialize
21212:  * a global LevelVar:
21213:  * 
21214:  * ```
21215:  * 	var programLevel = new(slog.LevelVar) // Info by default
21216:  * ```
21217:  * 
21218:  * Then use the LevelVar to construct a handler, and make it the default:
21219:  * 
21220:  * ```
21221:  * 	h := slog.NewJSONHandler(os.Stderr, &slog.HandlerOptions{Level: programLevel})
21222:  * 	slog.SetDefault(slog.New(h))
21223:  * ```
21224:  * 
21225:  * Now the program can change its logging level with a single statement:
21226:  * 
21227:  * ```
21228:  * 	programLevel.Set(slog.LevelDebug)
21229:  * ```
21230:  * 
21231:  * # Groups
21232:  * 
21233:  * Attributes can be collected into groups.
21234:  * A group has a name that is used to qualify the names of its attributes.
21235:  * How this qualification is displayed depends on the handler.
21236:  * [TextHandler] separates the group and attribute names with a dot.
21237:  * [JSONHandler] treats each group as a separate JSON object, with the group name as the key.
21238:  * 
21239:  * Use [Group] to create a Group attribute from a name and a list of key-value pairs:
21240:  * 
21241:  * ```
21242:  * 	slog.Group("request",
21243:  * 	    "method", r.Method,
21244:  * 	    "url", r.URL)
21245:  * ```
21246:  * 
21247:  * TextHandler would display this group as
21248:  * 
21249:  * ```
21250:  * 	request.method=GET request.url=http://example.com
21251:  * ```
21252:  * 
21253:  * JSONHandler would display it as
21254:  * 
21255:  * ```
21256:  * 	"request":{"method":"GET","url":"http://example.com"}
21257:  * ```
21258:  * 
21259:  * Use [Logger.WithGroup] to qualify all of a Logger's output
21260:  * with a group name. Calling WithGroup on a Logger results in a
21261:  * new Logger with the same Handler as the original, but with all
21262:  * its attributes qualified by the group name.
21263:  * 
21264:  * This can help prevent duplicate attribute keys in large systems,
21265:  * where subsystems might use the same keys.
21266:  * Pass each subsystem a different Logger with its own group name so that
21267:  * potential duplicates are qualified:
21268:  * 
21269:  * ```
21270:  * 	logger := slog.Default().With("id", systemID)
21271:  * 	parserLogger := logger.WithGroup("parser")
21272:  * 	parseInput(input, parserLogger)
21273:  * ```
21274:  * 
21275:  * When parseInput logs with parserLogger, its keys will be qualified with "parser",
21276:  * so even if it uses the common key "id", the log line will have distinct keys.
21277:  * 
21278:  * # Contexts
21279:  * 
21280:  * Some handlers may wish to include information from the [context.Context] that is
21281:  * available at the call site. One example of such information
21282:  * is the identifier for the current span when tracing is enabled.
21283:  * 
21284:  * The [Logger.Log] and [Logger.LogAttrs] methods take a context as a first
21285:  * argument, as do their corresponding top-level functions.
21286:  * 
21287:  * Although the convenience methods on Logger (Info and so on) and the
21288:  * corresponding top-level functions do not take a context, the alternatives ending
21289:  * in "Context" do. For example,
21290:  * 
21291:  * ```
21292:  * 	slog.InfoContext(ctx, "message")
21293:  * ```
21294:  * 
21295:  * It is recommended to pass a context to an output method if one is available.
21296:  * 
21297:  * # Attrs and Values
21298:  * 
21299:  * An [Attr] is a key-value pair. The Logger output methods accept Attrs as well as
21300:  * alternating keys and values. The statement
21301:  * 
21302:  * ```
21303:  * 	slog.Info("hello", slog.Int("count", 3))
21304:  * ```
21305:  * 
21306:  * behaves the same as
21307:  * 
21308:  * ```
21309:  * 	slog.Info("hello", "count", 3)
21310:  * ```
21311:  * 
21312:  * There are convenience constructors for [Attr] such as [Int], [String], and [Bool]
21313:  * for common types, as well as the function [Any] for constructing Attrs of any
21314:  * type.
21315:  * 
21316:  * The value part of an Attr is a type called [Value].
21317:  * Like an [any], a Value can hold any Go value,
21318:  * but it can represent typical values, including all numbers and strings,
21319:  * without an allocation.
21320:  * 
21321:  * For the most efficient log output, use [Logger.LogAttrs].
21322:  * It is similar to [Logger.Log] but accepts only Attrs, not alternating
21323:  * keys and values; this allows it, too, to avoid allocation.
21324:  * 
21325:  * The call
21326:  * 
21327:  * ```
21328:  * 	logger.LogAttrs(ctx, slog.LevelInfo, "hello", slog.Int("count", 3))
21329:  * ```
21330:  * 
21331:  * is the most efficient way to achieve the same output as
21332:  * 
21333:  * ```
21334:  * 	slog.InfoContext(ctx, "hello", "count", 3)
21335:  * ```
21336:  * 
21337:  * # Customizing a type's logging behavior
21338:  * 
21339:  * If a type implements the [LogValuer] interface, the [Value] returned from its LogValue
21340:  * method is used for logging. You can use this to control how values of the type
21341:  * appear in logs. For example, you can redact secret information like passwords,
21342:  * or gather a struct's fields in a Group. See the examples under [LogValuer] for
21343:  * details.
21344:  * 
21345:  * A LogValue method may return a Value that itself implements [LogValuer]. The [Value.Resolve]
21346:  * method handles these cases carefully, avoiding infinite loops and unbounded recursion.
21347:  * Handler authors and others may wish to use [Value.Resolve] instead of calling LogValue directly.
21348:  * 
21349:  * # Wrapping output methods
21350:  * 
21351:  * The logger functions use reflection over the call stack to find the file name
21352:  * and line number of the logging call within the application. This can produce
21353:  * incorrect source information for functions that wrap slog. For instance, if you
21354:  * define this function in file mylog.go:
21355:  * 
21356:  * ```
21357:  * 	func Infof(logger *slog.Logger, format string, args ...any) {
21358:  * 	    logger.Info(fmt.Sprintf(format, args...))
21359:  * 	}
21360:  * ```
21361:  * 
21362:  * and you call it like this in main.go:
21363:  * 
21364:  * ```
21365:  * 	Infof(slog.Default(), "hello, %s", "world")
21366:  * ```
21367:  * 
21368:  * then slog will report the source file as mylog.go, not main.go.
21369:  * 
21370:  * A correct implementation of Infof will obtain the source location
21371:  * (pc) and pass it to NewRecord.
21372:  * The Infof function in the package-level example called "wrapping"
21373:  * demonstrates how to do this.
21374:  * 
21375:  * # Working with Records
21376:  * 
21377:  * Sometimes a Handler will need to modify a Record
21378:  * before passing it on to another Handler or backend.
21379:  * A Record contains a mixture of simple public fields (e.g. Time, Level, Message)
21380:  * and hidden fields that refer to state (such as attributes) indirectly. This
21381:  * means that modifying a simple copy of a Record (e.g. by calling
21382:  * [Record.Add] or [Record.AddAttrs] to add attributes)
21383:  * may have unexpected effects on the original.
21384:  * Before modifying a Record, use [Record.Clone] to
21385:  * create a copy that shares no state with the original,
21386:  * or create a new Record with [NewRecord]
21387:  * and build up its Attrs by traversing the old ones with [Record.Attrs].
21388:  * 
21389:  * # Performance considerations
21390:  * 
21391:  * If profiling your application demonstrates that logging is taking significant time,
21392:  * the following suggestions may help.
21393:  * 
21394:  * If many log lines have a common attribute, use [Logger.With] to create a Logger with
21395:  * that attribute. The built-in handlers will format that attribute only once, at the
21396:  * call to [Logger.With]. The [Handler] interface is designed to allow that optimization,
21397:  * and a well-written Handler should take advantage of it.
21398:  * 
21399:  * The arguments to a log call are always evaluated, even if the log event is discarded.
21400:  * If possible, defer computation so that it happens only if the value is actually logged.
21401:  * For example, consider the call
21402:  * 
21403:  * ```
21404:  * 	slog.Info("starting request", "url", r.URL.String())  // may compute String unnecessarily
21405:  * ```
21406:  * 
21407:  * The URL.String method will be called even if the logger discards Info-level events.
21408:  * Instead, pass the URL directly:
21409:  * 
21410:  * ```
21411:  * 	slog.Info("starting request", "url", &r.URL) // calls URL.String only if needed
21412:  * ```
21413:  * 
21414:  * The built-in [TextHandler] will call its String method, but only
21415:  * if the log event is enabled.
21416:  * Avoiding the call to String also preserves the structure of the underlying value.
21417:  * For example [JSONHandler] emits the components of the parsed URL as a JSON object.
21418:  * If you want to avoid eagerly paying the cost of the String call
21419:  * without causing the handler to potentially inspect the structure of the value,
21420:  * wrap the value in a fmt.Stringer implementation that hides its Marshal methods.
21421:  * 
21422:  * You can also use the [LogValuer] interface to avoid unnecessary work in disabled log
21423:  * calls. Say you need to log some expensive value:
21424:  * 
21425:  * ```
21426:  * 	slog.Debug("frobbing", "value", computeExpensiveValue(arg))
21427:  * ```
21428:  * 
21429:  * Even if this line is disabled, computeExpensiveValue will be called.
21430:  * To avoid that, define a type implementing LogValuer:
21431:  * 
21432:  * ```
21433:  * 	type expensive struct { arg int }
21434:  * 
21435:  * 	func (e expensive) LogValue() slog.Value {
21436:  * 	    return slog.AnyValue(computeExpensiveValue(e.arg))
21437:  * 	}
21438:  * ```
21439:  * 
21440:  * Then use a value of that type in log calls:
21441:  * 
21442:  * ```
21443:  * 	slog.Debug("frobbing", "value", expensive{arg})
21444:  * ```
21445:  * 
21446:  * Now computeExpensiveValue will only be called when the line is enabled.
21447:  * 
21448:  * The built-in handlers acquire a lock before calling [io.Writer.Write]
21449:  * to ensure that exactly one [Record] is written at a time in its entirety.
21450:  * Although each log record has a timestamp,
21451:  * the built-in handlers do not use that time to sort the written records.
21452:  * User-defined handlers are responsible for their own locking and sorting.
21453:  * 
21454:  * # Writing a handler
21455:  * 
21456:  * For a guide to writing a custom handler, see https://golang.org/s/slog-handler-guide.
21457:  */
21458: namespace slog {
21459:  // @ts-ignore
21460:  import loginternal = internal
21461:  /**
21462:   * A Logger records structured information about each call to its
21463:   * Log, Debug, Info, Warn, and Error methods.
21464:   * For each call, it creates a [Record] and passes it to a [Handler].
21465:   * 
21466:   * To create a new Logger, call [New] or a Logger method
21467:   * that begins "With".
21468:   */
21469:  interface Logger {
21470:  }
21471:  interface Logger {
21472:   /**
21473:    * Handler returns l's Handler.
21474:    */
21475:   handler(): Handler
21476:  }
21477:  interface Logger {
21478:   /**
21479:    * With returns a Logger that includes the given attributes
21480:    * in each output operation. Arguments are converted to
21481:    * attributes as if by [Logger.Log].
21482:    */
21483:   with(...args: any[]): (Logger)
21484:  }
21485:  interface Logger {
21486:   /**
21487:    * WithGroup returns a Logger that starts a group, if name is non-empty.
21488:    * The keys of all attributes added to the Logger will be qualified by the given
21489:    * name. (How that qualification happens depends on the [Handler.WithGroup]
21490:    * method of the Logger's Handler.)
21491:    * 
21492:    * If name is empty, WithGroup returns the receiver.
21493:    */
21494:   withGroup(name: string): (Logger)
21495:  }
21496:  interface Logger {
21497:   /**
21498:    * Enabled reports whether l emits log records at the given context and level.
21499:    */
21500:   enabled(ctx: context.Context, level: Level): boolean
21501:  }
21502:  interface Logger {
21503:   /**
21504:    * Log emits a log record with the current time and the given level and message.
21505:    * The Record's Attrs consist of the Logger's attributes followed by
21506:    * the Attrs specified by args.
21507:    * 
21508:    * The attribute arguments are processed as follows:
21509:    * ```
21510:    *   - If an argument is an Attr, it is used as is.
21511:    *   - If an argument is a string and this is not the last argument,
21512:    *     the following argument is treated as the value and the two are combined
21513:    *     into an Attr.
21514:    *   - Otherwise, the argument is treated as a value with key "!BADKEY".
21515:    * ```
21516:    */
21517:   log(ctx: context.Context, level: Level, msg: string, ...args: any[]): void
21518:  }
21519:  interface Logger {
21520:   /**
21521:    * LogAttrs is a more efficient version of [Logger.Log] that accepts only Attrs.
21522:    */
21523:   logAttrs(ctx: context.Context, level: Level, msg: string, ...attrs: Attr[]): void
21524:  }
21525:  interface Logger {
21526:   /**
21527:    * Debug logs at [LevelDebug].
21528:    */
21529:   debug(msg: string, ...args: any[]): void
21530:  }
21531:  interface Logger {
21532:   /**
21533:    * DebugContext logs at [LevelDebug] with the given context.
21534:    */
21535:   debugContext(ctx: context.Context, msg: string, ...args: any[]): void
21536:  }
21537:  interface Logger {
21538:   /**
21539:    * Info logs at [LevelInfo].
21540:    */
21541:   info(msg: string, ...args: any[]): void
21542:  }
21543:  interface Logger {
21544:   /**
21545:    * InfoContext logs at [LevelInfo] with the given context.
21546:    */
21547:   infoContext(ctx: context.Context, msg: string, ...args: any[]): void
21548:  }
21549:  interface Logger {
21550:   /**
21551:    * Warn logs at [LevelWarn].
21552:    */
21553:   warn(msg: string, ...args: any[]): void
21554:  }
21555:  interface Logger {
21556:   /**
21557:    * WarnContext logs at [LevelWarn] with the given context.
21558:    */
21559:   warnContext(ctx: context.Context, msg: string, ...args: any[]): void
21560:  }
21561:  interface Logger {
21562:   /**
21563:    * Error logs at [LevelError].
21564:    */
21565:   error(msg: string, ...args: any[]): void
21566:  }
21567:  interface Logger {
21568:   /**
21569:    * ErrorContext logs at [LevelError] with the given context.
21570:    */
21571:   errorContext(ctx: context.Context, msg: string, ...args: any[]): void
21572:  }
21573: }
