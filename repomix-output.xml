 2840:  interface match {
 2841:   /**
 2842:    * Match reports whether name matches the shell file name pattern.
 2843:    * The pattern syntax is:
 2844:    * 
 2845:    * ```
 2846:    * 	pattern:
 2847:    * 		{ term }
 2848:    * 	term:
 2849:    * 		'*'         matches any sequence of non-Separator characters
 2850:    * 		'?'         matches any single non-Separator character
 2851:    * 		'[' [ '^' ] { character-range } ']'
 2852:    * 		            character class (must be non-empty)
 2853:    * 		c           matches character c (c != '*', '?', '\\', '[')
 2854:    * 		'\\' c      matches character c
 2855:    * 
 2856:    * 	character-range:
 2857:    * 		c           matches character c (c != '\\', '-', ']')
 2858:    * 		'\\' c      matches character c
 2859:    * 		lo '-' hi   matches character c for lo <= c <= hi
 2860:    * ```
 2861:    * 
 2862:    * Match requires pattern to match all of name, not just a substring.
 2863:    * The only possible returned error is [ErrBadPattern], when pattern
 2864:    * is malformed.
 2865:    * 
 2866:    * On Windows, escaping is disabled. Instead, '\\' is treated as
 2867:    * path separator.
 2868:    */
 2869:   (pattern: string, name: string): boolean
 2870:  }
 2871:  interface glob {
 2872:   /**
 2873:    * Glob returns the names of all files matching pattern or nil
 2874:    * if there is no matching file. The syntax of patterns is the same
 2875:    * as in [Match]. The pattern may describe hierarchical names such as
 2876:    * /usr/*\/bin/ed (assuming the [Separator] is '/').
 2877:    * 
 2878:    * Glob ignores file system errors such as I/O errors reading directories.
 2879:    * The only possible returned error is [ErrBadPattern], when pattern
 2880:    * is malformed.
 2881:    */
 2882:   (pattern: string): Array<string>
 2883:  }
 2884:  interface clean {
 2885:   /**
 2886:    * Clean returns the shortest path name equivalent to path
 2887:    * by purely lexical processing. It applies the following rules
 2888:    * iteratively until no further processing can be done:
 2889:    * 
 2890:    *  1. Replace multiple [Separator] elements with a single one.
 2891:    *  2. Eliminate each . path name element (the current directory).
 2892:    *  3. Eliminate each inner .. path name element (the parent directory)
 2893:    * ```
 2894:    *     along with the non-.. element that precedes it.
 2895:    * ```
 2896:    *  4. Eliminate .. elements that begin a rooted path:
 2897:    * ```
 2898:    *     that is, replace "/.." by "/" at the beginning of a path,
 2899:    *     assuming Separator is '/'.
 2900:    * ```
 2901:    * 
 2902:    * The returned path ends in a slash only if it represents a root directory,
 2903:    * such as "/" on Unix or `C:\` on Windows.
 2904:    * 
 2905:    * Finally, any occurrences of slash are replaced by Separator.
 2906:    * 
 2907:    * If the result of this process is an empty string, Clean
 2908:    * returns the string ".".
 2909:    * 
