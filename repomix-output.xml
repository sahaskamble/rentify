 8242:  interface BaseApp {
 8243:   /**
 8244:    * CreateBackup creates a new backup of the current app pb_data directory.
 8245:    * 
 8246:    * If name is empty, it will be autogenerated.
 8247:    * If backup with the same name exists, the new backup file will replace it.
 8248:    * 
 8249:    * The backup is executed within a transaction, meaning that new writes
 8250:    * will be temporary "blocked" until the backup file is generated.
 8251:    * 
 8252:    * To safely perform the backup, it is recommended to have free disk space
 8253:    * for at least 2x the size of the pb_data directory.
 8254:    * 
 8255:    * By default backups are stored in pb_data/backups
 8256:    * (the backups directory itself is excluded from the generated backup).
 8257:    * 
 8258:    * When using S3 storage for the uploaded collection files, you have to
 8259:    * take care manually to backup those since they are not part of the pb_data.
 8260:    * 
 8261:    * Backups can be stored on S3 if it is configured in app.Settings().Backups.
 8262:    */
 8263:   createBackup(ctx: context.Context, name: string): void
 8264:  }
 8265:  interface BaseApp {
 8266:   /**
 8267:    * RestoreBackup restores the backup with the specified name and restarts
 8268:    * the current running application process.
 8269:    * 
 8270:    * NB! This feature is experimental and currently is expected to work only on UNIX based systems.
 8271:    * 
 8272:    * To safely perform the restore it is recommended to have free disk space
 8273:    * for at least 2x the size of the restored pb_data backup.
 8274:    * 
 8275:    * The performed steps are:
 8276:    * 
 8277:    *  1. Download the backup with the specified name in a temp location
 8278:    * ```
 8279:    *     (this is in case of S3; otherwise it creates a temp copy of the zip)
 8280:    * ```
 8281:    * 
 8282:    *  2. Extract the backup in a temp directory inside the app "pb_data"
 8283:    * ```
 8284:    *     (eg. "pb_data/.pb_temp_to_delete/pb_restore").
 8285:    * ```
 8286:    * 
 8287:    *  3. Move the current app "pb_data" content (excluding the local backups and the special temp dir)
 8288:    * ```
 8289:    *     under another temp sub dir that will be deleted on the next app start up
 8290:    *     (eg. "pb_data/.pb_temp_to_delete/old_pb_data").
 8291:    *     This is because on some environments it may not be allowed
 8292:    *     to delete the currently open "pb_data" files.
 8293:    * ```
 8294:    * 
 8295:    *  4. Move the extracted dir content to the app "pb_data".
 8296:    * 
 8297:    *  5. Restart the app (on successful app bootstrap it will also remove the old pb_data).
 8298:    * 
 8299:    * If a failure occur during the restore process the dir changes are reverted.
 8300:    * If for whatever reason the revert is not possible, it panics.
 8301:    * 
 8302:    * Note that if your pb_data has custom network mounts as subdirectories, then
 8303:    * it is possible the restore to fail during the `os.Rename` operations
 8304:    * (see https://github.com/pocketbase/pocketbase/issues/4647).
 8305:    */
 8306:   restoreBackup(ctx: context.Context, name: string): void
 8307:  }
